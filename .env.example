# Required
AGENT_NAME=research
AGENT_DESCRIPTION=Research agent — web search, data gathering, analysis, and summarization
AGENT_CAPABILITIES=research,web-search,summarize
AGENT_SLACK_CHANNEL=#agent-research
AGENT_ENDPOINT=http://agent-research:3000
